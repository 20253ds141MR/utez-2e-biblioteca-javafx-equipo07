<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.utez2epacientesjavafxequipo07.controllers.FormularioController">
   <children>
      <Label alignment="CENTER" prefHeight="18.0" prefWidth="612.0" style="-fx-background-size: 18; -fx-font-weight: bold;" text="FORMULARIO">
         <font>
            <Font size="16.0" />
         </font></Label>
      <GridPane prefHeight="297.0" prefWidth="600.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="295.0" minWidth="10.0" prefWidth="149.6" />
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="451.19999999999993" minWidth="10.0" prefWidth="451.19999999999993" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="ID" />
            <Label text="Título" GridPane.rowIndex="1" />
            <Label text="Autor" GridPane.rowIndex="2" />
            <Label text="Año" GridPane.rowIndex="3" />
            <Label text="Género" GridPane.rowIndex="4" />
            <CheckBox fx:id="checkDisponible" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" text="Disponible" GridPane.rowIndex="5" />
            <TextField fx:id="txtId" GridPane.columnIndex="1" />
            <TextField fx:id="txtTitulo" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <TextField fx:id="txtAutor" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <TextField fx:id="txtAnio" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <TextField fx:id="txtGenero" GridPane.columnIndex="1" GridPane.rowIndex="4" />
         </children>
      </GridPane>
      <ButtonBar prefHeight="40.0" prefWidth="200.0">
        <buttons>
          <Button mnemonicParsing="false" onAction="#agregar" text="Agregar" />
            <Button mnemonicParsing="false" onAction="#guardar" text="Guardar" />
        </buttons>
      </ButtonBar>
   </children>
</VBox>
